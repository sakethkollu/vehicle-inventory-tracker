# Optional: skip Playwright cookie fetch during Mazda ingest.
# MAZDA_SESSION_COOKIE=
# MAZDA_DATABASE_URL=mysql+pymysql://vit:password@127.0.0.1:3306/mazda_inventory

# Default make in UI when no session is set (toyota|mazda)
# DEFAULT_MAKE=toyota

# Optional: skip Playwright WAF token fetch during Toyota ingest.
# TOYOTA_WAF_TOKEN=

# Database (MySQL required)
# For Docker Compose: set MYSQL_* below only — compose injects DATABASE_URL=@mysql:3306.
# Do NOT point DATABASE_URL at 127.0.0.1 unless the web container uses network_mode: host.
#
# Local MySQL (non-Docker):
# DATABASE_URL=mysql+pymysql://vit:password@127.0.0.1:3306/vehicle_inventory
#
# Docker MySQL (data in Docker volume `mysql_data`; wipe with `docker compose down -v`):
# MYSQL_ROOT_PASSWORD=change_me_root
# MYSQL_DATABASE=vehicle_inventory
# MYSQL_USER=vit
# MYSQL_PASSWORD=change_me
# MAZDA_DATABASE=mazda_inventory

# Redis job queue (required for docker worker; optional locally)
# REDIS_URL=redis://localhost:6379/0
# USE_REDIS_JOBS=1
# WORKER_CONCURRENCY=2

# Admin dashboard at /admin
# ADMIN_PASSWORD=your-secret-password
# FLASK_SECRET_KEY=change-me-in-production

# Logging
# LOG_JSON=1
# LOG_LEVEL=INFO

# Dev UIs (docker compose up)
# ADMINER_PORT=8080
# REDIS_COMMANDER_PORT=8081
# Adminer: http://127.0.0.1:8080 — System: MySQL, Server: mysql, User/Password/Database from above
# Redis Commander: http://127.0.0.1:8081
